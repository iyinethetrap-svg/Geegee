--[[
    KeyBinds:
    Y = Turn ON ESP
    U = Turn OFF ESP
]]--

-- Disable error reporting
for i, v in pairs(getconnections(game:GetService("ScriptContext").Error)) do 
    v:Disable()
end

-- Global Toggle Setup
if getgenv().ESPTOGGLE1 ~= nil then 
    getgenv().ESPTOGGLE1 = nil
end
getgenv().ESPTOGGLE1 = true

local MarketplaceService = game:GetService("MarketplaceService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local wrksp = game:GetService("Workspace")

local ToggleKey = Enum.KeyCode.Y
local HideKey = Enum.KeyCode.U
local RefreshRate = 14 
local Vec2Offset = Vector2.new(0, 15)
local Camera = wrksp.CurrentCamera

-- CACHE: Prevents lag by remembering names we already looked up
local ID_Cache = {}

-- Function to get Name from Asset ID
local function getOfficialName(assetString)
    local cleanId = tonumber(string.match(tostring(assetString), "%d+"))
    if not cleanId then return nil end

    if ID_Cache[cleanId] then return ID_Cache[cleanId] end

    local success, info = pcall(function()
        return MarketplaceService:GetProductInfoAsync(cleanId)
    end)

    if success and info and info.Name then
        ID_Cache[cleanId] = info.Name
        return info.Name
    end
    return nil
end

-- Function to convert World Position to Screen Position
local function WTS(Position)
    local VP, onscreen = Camera:WorldToViewportPoint(Position)
    return Vector2.new(VP.X, VP.Y), onscreen, VP.Z
end

-- DYNAMIC NAME RESOLVER
local function resolveItemName(Character)
    local meshId = ""
    
    -- 1. Get the ID
    if Character:IsA("MeshPart") then
        meshId = Character.MeshId
    else
        local sm = Character:FindFirstChildWhichIsA("SpecialMesh")
        if sm then meshId = sm.MeshId end
    end

    -- 2. Try Auto-Resolve from Roblox
    local officialName = getOfficialName(meshId)
    if officialName then return officialName end

    -- 3. Check for Orb Particles
    if Character:FindFirstChild("OrbParticle") then return "???" end

    -- 4. Check Parent Name (if not generic)
    local pName = Character.Parent and Character.Parent.Name
    if pName and pName ~= "Model" and pName ~= "Part" and pName ~= "Workspace" and pName ~= "Folder" then
        return pName
    end

    -- 5. Final Fallback
    return Character.Name
end

function CreateESP(TargetPart)
    if not TargetPart then return end

    local Name = Drawing.new("Text")
    Name.Visible = false
    Name.Center = true
    Name.Outline = true
    Name.Font = 0
    Name.Size = 18
    Name.Color = Color3.fromRGB(141, 255, 126)
    Name.Text = resolveItemName(TargetPart)

    local DistanceTag = Drawing.new("Text")
    DistanceTag.Visible = false
    DistanceTag.Center = true
    DistanceTag.Outline = true
    DistanceTag.Font = 0
    DistanceTag.Size = 16
    DistanceTag.Color = Color3.fromRGB(192, 192, 192)

    local Connection
    Connection = RunService.RenderStepped:Connect(function()
        if not TargetPart:IsDescendantOf(wrksp) then
            Name:Remove()
            DistanceTag:Remove()
            Connection:Disconnect()
            return
        end

        if getgenv().ESPTOGGLE1 then
            local Pos, OnScreen, Dist = WTS(TargetPart.Position)
            if OnScreen then
                Name.Position = Pos
                DistanceTag.Position = Pos + Vec2Offset
                DistanceTag.Text = string.format("[%d]", Dist)
                
                Name.Visible = true
                DistanceTag.Visible = true
            else
                Name.Visible = false
                DistanceTag.Visible = false
            end
        else
            Name.Visible = false
            DistanceTag.Visible = false
        end
    end)
end

-- Scanner Logic
local function scanObject(v)
    if v:IsA("MeshPart") or v:IsA("UnionOperation") or v:IsA("Part") then 
        for _, child in pairs(v:GetDescendants()) do 
            if child:IsA("ClickDetector") or child:IsA("ProximityPrompt") then 
                CreateESP(v)
                break -- Only one ESP per part
            end
        end
    end
end

-- Initial scan & setup listeners
for _, v in pairs(wrksp:GetChildren()) do scanObject(v) end
wrksp.ChildAdded:Connect(function(v)
    task.wait(0.1)
    scanObject(v)
end)

-- Keybind Handling
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == ToggleKey then
        getgenv().ESPTOGGLE1 = true
    elseif input.KeyCode == HideKey then
        getgenv().ESPTOGGLE1 = false
    end
end)
