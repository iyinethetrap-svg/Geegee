--[[
    Pickupable Item ESP (Fixed for "Part" and "Render Mesh")
    Keys: Y = ON | U = OFF
]]--

if getgenv().ESPTOGGLE1 ~= nil then getgenv().ESPTOGGLE1 = nil end
getgenv().ESPTOGGLE1 = true

local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local wrksp = game:GetService("Workspace")
local Camera = wrksp.CurrentCamera

local ToggleKey = Enum.KeyCode.Y
local HideKey = Enum.KeyCode.U

-- Names we want to IGNORE because they are useless
local GenericNames = {
    ["Part"] = true, ["MeshPart"] = true, ["Handle"] = true, 
    ["Union"] = true, ["Render Mesh"] = true, ["Model"] = true,
    ["Folder"] = true, ["Workspace"] = true, ["Mesh"] = true
}

-- 1. DEEP RESOLVER: Looks up the family tree for a real name
local function getDeepName(Object)
    local current = Object
    
    -- Loop upwards up to 4 times to find a non-generic parent name
    for i = 1, 4 do
        if not current or current == wrksp then break end
        
        local name = current.Name
        if not GenericNames[name] then
            return name
        end
        current = current.Parent
    end
    
    -- If everything is generic, check if it's a Tool
    local tool = Object:FindFirstAncestorOfClass("Tool")
    if tool then return tool.Name end
    
    return "Unknown Item"
end

-- 2. ESP UI CREATION
function CreateESP(TargetPart)
    if not TargetPart then return end

    local NameTag = Drawing.new("Text")
    NameTag.Visible = false
    NameTag.Center = true
    NameTag.Outline = true
    NameTag.Font = 0
    NameTag.Size = 18
    NameTag.Color = Color3.fromRGB(255, 213, 0) -- Gold/Yellow for loot
    NameTag.Text = getDeepName(TargetPart)

    local DistTag = Drawing.new("Text")
    DistTag.Visible = false
    DistTag.Center = true
    DistTag.Outline = true
    DistTag.Font = 0
    DistTag.Size = 14
    DistTag.Color = Color3.fromRGB(200, 200, 200)

    local function WTS(Pos)
        local VP, onscreen = Camera:WorldToViewportPoint(Pos)
        return Vector2.new(VP.X, VP.Y), onscreen, VP.Z
    end

    local Connection
    Connection = RunService.RenderStepped:Connect(function()
        if not TargetPart:IsDescendantOf(wrksp) then
            NameTag:Remove(); DistTag:Remove(); Connection:Disconnect()
            return
        end

        if getgenv().ESPTOGGLE1 then
            local Pos, OnScreen, Dist = WTS(TargetPart.Position)
            if OnScreen then
                NameTag.Position = Pos
                DistTag.Position = Pos + Vector2.new(0, 15)
                DistTag.Text = "[" .. math.floor(Dist) .. "m]"
                NameTag.Visible, DistTag.Visible = true, true
            else
                NameTag.Visible, DistTag.Visible = false, false
            end
        else
            NameTag.Visible, DistTag.Visible = false, false
        end
    end)
end

-- 3. INTERACTIVE SCANNER (Finds items you can actually pick up)
local function check(v)
    if v:IsA("BasePart") then 
        -- Look for things that make an item "pickupable"
        local hasTrigger = v:FindFirstChildWhichIsA("ClickDetector") or v:FindFirstChildWhichIsA("ProximityPrompt")
        
        -- Also check the parent in case the trigger is there
        if not hasTrigger and v.Parent then
            hasTrigger = v.Parent:FindFirstChildWhichIsA("ClickDetector") or v.Parent:FindFirstChildWhichIsA("ProximityPrompt")
        end

        if hasTrigger then
            CreateESP(v)
        end
    end
end

-- Start
for _, v in pairs(wrksp:GetDescendants()) do check(v) end
wrksp.DescendantAdded:Connect(function(v)
    task.wait(0.1)
    check(v)
end)

-- Toggles
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == ToggleKey then getgenv().ESPTOGGLE1 = true
    elseif input.KeyCode == HideKey then getgenv().ESPTOGGLE1 = false end
end)
