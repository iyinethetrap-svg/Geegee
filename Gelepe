local ToggleKey = Enum.KeyCode.Y
local HideCommonToggleKey = Enum.KeyCode.U

local Meshes = {
    ["rbxassetid://16657069"] = "Money Bag",
    ["rbxassetid://60791940"] = "Scroll",
    ["rbxassetid://2877143560"] = "Jewel",
    ["rbxassetid://2637545558"] = "Ring",
