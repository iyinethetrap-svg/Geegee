    ["rbxassetid://5196776695"] = "Ring",
}

local RefreshRate = 14 -- ms
local wrksp = game:GetService("Workspace")
local Camera = wrksp.CurrentCamera
local WTVP = Camera.WorldToViewportPoint
local Vec2 = Vector2.new(0, 15)
local strformat = string.format

function WTS(Position)
    local VP, onscreen = WTVP(Camera, Position)
    return Vector2.new(VP.X, VP.Y), onscreen, VP.Z
end

function CreateESP(Character)
    if not Character then return end

    local Name = Drawing.new("Text")
    Name.Color = Color3.fromRGB(141, 255, 126)
    Name.Size = 18
    Name.Outline = true
    Name.Center = true
    Name.Font = 0

    local Bottom = Drawing.new("Text")
    Bottom.Color = Color3.fromRGB(192,192,192)
    Bottom.Size = 18
    Bottom.Outline = true
    Bottom.Center = true
    Bottom.Font = 0

    -- FIXED NAMING LOGIC
    pcall(function()
        local parent = Character.Parent
        local meshId

        if parent:IsA("MeshPart") then
            meshId = parent.MeshId
        elseif parent:IsA("Part") then
            local sm = parent:FindFirstChildWhichIsA("SpecialMesh")
            if sm then meshId = sm.MeshId end
        end

        if meshId and Meshes[meshId] then
            Name.Text = Meshes[meshId]
        elseif parent:FindFirstChild("OrbParticle") then
            Name.Text = "???"
        else
            Name.Text = parent.Name
        end
    end)

    local LastRefresh = 0
    local Con

    Con = game:GetService("RunService").RenderStepped:Connect(function()
        if (tick() - LastRefresh) > (RefreshRate / 1000) then
            LastRefresh = tick()

            if not Character:IsDescendantOf(workspace) then
                Con:Disconnect()
                Name:Remove()
                Bottom:Remove()
                return
            end

            local Pos, OnScreen, Dist = WTS(Character.Position)

            if OnScreen and getgenv().ESPTOGGLE1 then
                Name.Position = Pos
                Bottom.Position = Pos + Vec2
                Bottom.Text = strformat("[%d]", Dist)

                Name.Visible = true
                Bottom.Visible = true
            else
                Name.Visible = false
                Bottom.Visible = false
            end
        end
    end)
end

-- INITIAL SCAN
for _, v in pairs(wrksp:GetChildren()) do 
    if v:IsA("MeshPart") or v:IsA("UnionOperation") or v:IsA("Part") then 
        for _, v2 in pairs(v:GetDescendants()) do 
            if v2:IsA("ClickDetector") then 
                CreateESP(v2.Parent)
            end
        end
    end
end

-- NEW OBJECTS
wrksp.ChildAdded:Connect(function(v)
    if v:IsA("MeshPart") or v:IsA("UnionOperation") or v:IsA("Part") then 
        for _, v2 in pairs(v:GetDescendants()) do 
            if v2:IsA("ClickDetector") then 
                CreateESP(v2.Parent)
            end
        end
    end
end)

-- TOGGLE KEYS
game:GetService("UserInputService").InputBegan:Connect(function(inputObject)
    if inputObject.KeyCode == ToggleKey then
        getgenv().ESPTOGGLE1 = true
    elseif inputObject.KeyCode == HideCommonToggleKey then
        getgenv().ESPTOGGLE1 = false
    end
end
